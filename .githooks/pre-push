#!/usr/bin/env bash
#
# Pre-push hook: block pushes if branch is behind origin/main.
# Prevents the stale-branch problem where devs branch off old local state.
#
# Install: git config core.hooksPath .githooks

set -euo pipefail

MAIN_BRANCH="main"
REMOTE="origin"

# Get the current branch
CURRENT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || true)

# Skip check for main itself (direct pushes allowed if no branch protection)
if [ "$CURRENT_BRANCH" = "$MAIN_BRANCH" ]; then
    exit 0
fi

# Skip if we can't determine the branch (detached HEAD)
if [ -z "$CURRENT_BRANCH" ]; then
    exit 0
fi

# Fetch latest main quietly
git fetch "$REMOTE" "$MAIN_BRANCH" --quiet 2>/dev/null || {
    echo "WARNING: Could not fetch $REMOTE/$MAIN_BRANCH. Skipping freshness check."
    exit 0
}

# Check if origin/main is an ancestor of the current branch
if ! git merge-base --is-ancestor "$REMOTE/$MAIN_BRANCH" HEAD 2>/dev/null; then
    BEHIND=$(git rev-list --count "HEAD..$REMOTE/$MAIN_BRANCH" 2>/dev/null || echo "unknown")
    echo ""
    echo "========================================="
    echo " PUSH BLOCKED: branch is behind $REMOTE/$MAIN_BRANCH"
    echo "========================================="
    echo ""
    echo " Your branch '$CURRENT_BRANCH' is $BEHIND commit(s) behind $REMOTE/$MAIN_BRANCH."
    echo " This causes overlapping PRs and merge conflicts."
    echo ""
    echo " Fix:"
    echo "   git fetch $REMOTE"
    echo "   git rebase $REMOTE/$MAIN_BRANCH"
    echo ""
    exit 1
fi

exit 0
