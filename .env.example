# =============================================================================
# Docker Compose
# Docker compose env vars to enable simple switching between SQLite (default) and PostgreSQL for auth DB and wiki storage.
# Enables just simple "docker compose up --build -d" with the desired configuration without needing to edit compose files or set multiple env vars.
# =============================================================================
# Run with PostgreSQL:
# COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml:docker-compose.postgres.yml
# Run with SQLite (default):
# COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
# Enable PostgreSQL services (auth DB and/or wiki storage) with:
# COMPOSE_PROFILES=postgres

# =============================================================================
# LLM Configuration
# =============================================================================
# Supported providers: openai | anthropic | gemini | ollama | bedrock | github | copilot | custom
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_MODEL_LOW=                          # Optional low-tier model for quality checks (falls back to LLM_MODEL)

# Embeddings (defaults to LLM provider & key when not set)
EMBEDDING_PROVIDER=                     # Defaults to LLM_PROVIDER; set explicitly for anthropic/copilot (e.g. openai)
EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_API_KEY=                    # Separate key if embeddings use a different provider
# EMBEDDING_API_BASE=                   # Separate base URL for embeddings

# Concurrency
LLM_MAX_CONCURRENCY=4                   # Max parallel LLM calls during wiki generation (lower for Ollama, e.g. 1-2)

# Retry & fallback
LLM_MAX_RETRIES=5
LLM_TIMEOUT=900                         # seconds (15 min)
# LLM_FALLBACK_MODELS=claude-sonnet-4-6,gpt-4o-mini  # Comma-separated fallback chain
# LLM_FALLBACK_PROVIDER=               # Provider for fallback models if different from LLM_PROVIDER

# -----------------------------------------------------------------------------
# Provider examples (uncomment one block)
# -----------------------------------------------------------------------------

# --- OpenAI (default) ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL_LOW=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-large

# --- Anthropic ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-sonnet-4-5-20250514
# LLM_MODEL_LOW=claude-haiku-4-5-20251001
# EMBEDDING_PROVIDER=openai              # Anthropic has no embedding API
# EMBEDDING_API_KEY=sk-your-openai-key

# --- Google Gemini ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-key
# LLM_MODEL=gemini-2.5-flash
# LLM_MODEL_LOW=gemini-2.5-flash
# EMBEDDING_MODEL=models/text-embedding-004

# --- Ollama (local) ---
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_NUM_CTX=32768
# EMBEDDING_MODEL=nomic-embed-text

# --- AWS Bedrock ---
# LLM_PROVIDER=bedrock
# LLM_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=                    # Optional — falls back to IAM role / boto3 default chain
# AWS_SECRET_ACCESS_KEY=
# EMBEDDING_MODEL=amazon.titan-embed-text-v1

# --- GitHub Models (free tier available) ---
# LLM_PROVIDER=github
# LLM_API_KEY=ghp_your-github-pat      # GitHub PAT with models:read permission
# LLM_MODEL=openai/gpt-4o              # Also: claude-sonnet-4-5, meta-llama-3.1-405b, etc.
# EMBEDDING_MODEL=text-embedding-3-small
# GITHUB_MODELS_BASE_URL=https://models.inference.ai.azure.com

# --- GitHub Copilot ---
# LLM_PROVIDER=copilot
# LLM_API_KEY=gho_your-github-oauth-token  # GitHub OAuth token with Copilot access
# LLM_MODEL=gpt-4o
# GITHUB_COPILOT_BASE_URL=https://api.githubcopilot.com
# EMBEDDING_PROVIDER=openai              # Copilot has no embedding API
# EMBEDDING_API_KEY=sk-your-openai-key

# --- Custom (any OpenAI-compatible API) ---
# LLM_PROVIDER=custom
# LLM_API_KEY=your-key
# LLM_API_BASE=http://localhost:8080/v1
# LLM_MODEL=your-model-name

# Storage
STORAGE_BACKEND=local
STORAGE_PATH=/app/data/artifacts
CACHE_DIR=/app/data/cache

# Database (auth service)
# SQLite (default): omit or leave commented out
# PostgreSQL: uncomment and set connection string
# DATABASE_URL=postgresql://wikis:wikis@localhost:5432/wikis_auth

# Wiki Storage Backend
# Default: sqlite (per-repo .wiki.db files under CACHE_DIR)
# PostgreSQL: set backend + DSN (uses schema-per-repo isolation)
# WIKI_STORAGE_BACKEND=postgres
# WIKI_STORAGE_DSN=postgresql://wikis:wikis@localhost:5432/wikis_store

# Auth
BETTER_AUTH_URL=http://localhost:3000    # Public URL of the web app (used for cookie security + trusted origins)
FRONTEND_URL=                            # Set if different from BETTER_AUTH_URL (e.g. custom domain)
AUTH_SECRET=change-me-in-development
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# RS256 JWT keys (cross-service auth: app → backend)
# Generate with:
#   openssl genrsa -out web/keys/private.pem 2048
#   openssl rsa -in web/keys/private.pem -pubout -out web/keys/public.pem
JWT_PRIVATE_KEY=  # Contents of private.pem
JWT_PUBLIC_KEY=   # Contents of public.pem

# Backend URL (used by Next.js rewrites in Docker)
BACKEND_URL=http://backend:8000

# MCP Server
WIKIS_BACKEND_URL=http://localhost:8000  # or http://backend:8000 in Docker

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=  # Google Analytics V4 (e.g. G-XXXXXXXXXX)

# General
LOG_LEVEL=INFO
NODE_ENV=development

# ── Embedding HTTP batch size ─────────────────────────────────────────
# Number of texts per /embeddings POST.  Defaults to 256.  Provider
# limit is 2048 inputs / ~300k tokens per request for
# text-embedding-3-large; bump higher on big repos to amortise HTTP RTT
# (which dominates wall-clock when the per-request payload is small).
#WIKI_EMBED_BATCH_SIZE=512

# Concurrency (number of parallel workers for embedding phase; adjust based on CPU/RAM and provider rate limits)
#WIKI_EMBED_CONCURRENCY=4
# Concurrency for vector store operations (e.g. Semantic orphan edge detection)
#WIKI_VEC_CONCURRENCY=4
# Concurrency for naming phase (LLM calls); set lower for Ollama or if hitting rate limits
#WIKI_NAMING_CONCURRENCY=4
# Naming order: whether to prioritise naming pages first (pages_first) or allow section and afterwards pages (balanced)
# Recommendation: keep it pages_first for better performance and more coherent section and pages names
#WIKI_NAMING_ORDER=pages_first
# Whether to perform an additional deduplication pass to remove redundant edges after initial graph construction (can help reduce noise in large repos with many similar files)
#WIKI_DEDUP_EDGES=1


# Wiki Generation — Structure Planner
# PLANNER_TYPE=agent           # agent (LLM-driven) | cluster (graph-based Leiden clustering)
# CLUSTER_HUB_Z_THRESHOLD=3.0 # Z-score threshold for hub detection in cluster planner
# CLUSTER_EXCLUDE_TESTS=true   # Exclude test files from cluster analysis

# Wiki Generation — Graph Enrichment
# GRAPH_ENRICHMENT_ENABLED=true  # Enable Phase 2 topology enrichment (doc edges, component bridging)
# HUB_Z_THRESHOLD=3.0            # Z-score threshold for hub detection
# VEC_DISTANCE_THRESHOLD=0.15    # Vector distance threshold for semantic edges
