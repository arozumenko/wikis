  "components": {
    "schemas": {
      "AskRequest": {
        "description": "Request to ask a question about a wiki.",
        "properties": {
          "wiki_id": {
            "title": "Wiki Id",
            "type": "string"
          },
          "question": {
            "title": "Question",
            "type": "string"
          },
          "chat_history": {
            "items": {
              "$ref": "#/components/schemas/ChatMessage"
            },
            "title": "Chat History",
            "type": "array"
          },
          "k": {
            "default": 15,
            "title": "K",
            "type": "integer"
          }
        },
        "required": [
          "wiki_id",
          "question"
        ],
        "title": "AskRequest",
        "type": "object"
      },
      "AskResponse": {
        "description": "Response to an ask question.",
        "properties": {
          "answer": {
            "title": "Answer",
            "type": "string"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/SourceReference"
            },
            "title": "Sources",
            "type": "array"
          }
        },
        "required": [
          "answer"
        ],
        "title": "AskResponse",
        "type": "object"
      },
      "ChatMessage": {
        "description": "A single chat message.",
        "properties": {
          "role": {
            "title": "Role",
            "type": "string"
          },
          "content": {
            "title": "Content",
            "type": "string"
          }
        },
        "required": [
          "role",
          "content"
        ],
        "title": "ChatMessage",
        "type": "object"
      },
      "DeleteWikiResponse": {
        "description": "Response after deleting a wiki.",
        "properties": {
          "deleted": {
            "title": "Deleted",
            "type": "boolean"
          },
          "wiki_id": {
            "title": "Wiki Id",
            "type": "string"
          }
        },
        "required": [
          "deleted",
          "wiki_id"
        ],
        "title": "DeleteWikiResponse",
        "type": "object"
      },
      "ErrorResponse": {
        "description": "Standard error response.",
        "properties": {
          "error": {
            "title": "Error",
            "type": "string"
          },
          "detail": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Detail"
          },
          "code": {
            "title": "Code",
            "type": "string"
          }
        },
        "required": [
          "error",
          "code"
        ],
        "title": "ErrorResponse",
        "type": "object"
      },
      "GenerateWikiRequest": {
        "description": "Request to generate a wiki from a repository.",
        "properties": {
          "repo_url": {
            "title": "Repo Url",
            "type": "string"
          },
          "branch": {
            "default": "main",
            "title": "Branch",
            "type": "string"
          },
          "provider": {
            "default": "github",
            "title": "Provider",
            "type": "string"
          },
          "access_token": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Access Token"
          },
          "wiki_title": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Wiki Title"
          },
          "include_research": {
            "default": true,
            "title": "Include Research",
            "type": "boolean"
          },
          "include_diagrams": {
            "default": true,
            "title": "Include Diagrams",
            "type": "boolean"
          },
          "force_rebuild_index": {
            "default": true,
            "title": "Force Rebuild Index",
            "type": "boolean"
          },
          "llm_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Llm Model"
          },
          "embedding_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Embedding Model"
          },
          "visibility": {
            "default": "personal",
            "title": "Visibility",
            "type": "string"
          }
        },
        "required": [
          "repo_url"
        ],
        "title": "GenerateWikiRequest",
        "type": "object"
      },
      "GenerateWikiResponse": {
        "description": "Response after initiating wiki generation.",
        "properties": {
          "wiki_id": {
            "title": "Wiki Id",
            "type": "string"
          },
          "invocation_id": {
            "title": "Invocation Id",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "message": {
            "title": "Message",
            "type": "string"
          }
        },
        "required": [
          "wiki_id",
          "invocation_id",
          "status",
          "message"
        ],
        "title": "GenerateWikiResponse",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "description": "Health check response.",
        "properties": {
          "status": {
            "title": "Status",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          },
          "services": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Services",
            "type": "object"
          }
        },
        "required": [
          "status",
          "version"
        ],
        "title": "HealthResponse",
        "type": "object"
      },
      "Invocation": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "wiki_id": {
            "type": "string",
            "title": "Wiki Id"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "default": "generating"
          },
          "progress": {
            "type": "number",
            "title": "Progress",
            "default": 0.0
          },
          "current_phase": {
            "type": "string",
            "title": "Current Phase",
            "default": ""
          },
          "message": {
            "type": "string",
            "title": "Message",
            "default": ""
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "completed_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completed At"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "pages_completed": {
            "type": "integer",
            "title": "Pages Completed",
            "default": 0
          },
          "pages_total": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pages Total"
          },
          "estimated_tokens": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Estimated Tokens"
          },
          "model_context_limit": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Model Context Limit"
          }
        },
        "type": "object",
        "required": [
          "id",
          "wiki_id"
        ],
        "title": "Invocation",
        "description": "Tracks the state of a background wiki generation job."
      },
      "ResearchRequest": {
        "description": "Request to perform deep research on a wiki.",
        "properties": {
          "wiki_id": {
            "title": "Wiki Id",
            "type": "string"
          },
          "question": {
            "title": "Question",
            "type": "string"
          },
          "research_type": {
            "default": "general",
            "title": "Research Type",
            "type": "string"
          },
          "enable_subagents": {
            "default": true,
            "title": "Enable Subagents",
            "type": "boolean"
          }
        },
        "required": [
          "wiki_id",
          "question"
        ],
        "title": "ResearchRequest",
        "type": "object"
      },
      "ResearchResponse": {
        "description": "Response from deep research.",
        "properties": {
          "answer": {
            "title": "Answer",
            "type": "string"
          },
          "sources": {
            "items": {
              "$ref": "#/components/schemas/SourceReference"
            },
            "title": "Sources",
            "type": "array"
          },
          "research_steps": {
            "items": {
              "type": "string"
            },
            "title": "Research Steps",
            "type": "array"
          },
          "code_map": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/CodeMapData"
              },
              {
                "type": "null"
              }
            ],
            "title": "Code Map"
          }
        },
        "required": [
          "answer"
        ],
        "title": "ResearchResponse",
        "type": "object"
      },
      "SourceReference": {
        "description": "A reference to a source code location.",
        "properties": {
          "file_path": {
            "title": "File Path",
            "type": "string"
          },
          "line_start": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Line Start"
          },
          "line_end": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Line End"
          },
          "snippet": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Snippet"
          }
        },
        "required": [
          "file_path"
        ],
        "title": "SourceReference",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
